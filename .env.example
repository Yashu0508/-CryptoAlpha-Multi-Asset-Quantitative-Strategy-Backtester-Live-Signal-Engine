APP_NAME=CryptoAlpha
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://cryptoalpha:cryptoalpha@db:5432/cryptoalpha
POSTGRES_DB=cryptoalpha
POSTGRES_USER=cryptoalpha
POSTGRES_PASSWORD=cryptoalpha
CORS_ORIGINS=http://localhost:5173
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
COINGECKO_TIMEOUT_SECONDS=10
COINGECKO_MAX_RETRIES=3
BINANCE_REST_BASE_URL=https://api.binance.com/api/v3
BINANCE_WEBSOCKET_BASE_URL=wss://stream.binance.com:9443/ws
BINANCE_TIMEOUT_SECONDS=10
BINANCE_MAX_RETRIES=3
BINANCE_WEBSOCKET_RECONNECT_MAX_DELAY_SECONDS=30
COINMARKETCAP_BASE_URL=https://pro-api.coinmarketcap.com
COINMARKETCAP_API_KEY=
COINMARKETCAP_TIMEOUT_SECONDS=10
COINMARKETCAP_MAX_RETRIES=3
DEXSCREENER_BASE_URL=https://api.dexscreener.com
